{
    "manifest_version": 3,
    "name": "Inleo Skins",
    "version": "1.1",
    "description": "Customizable themes and skins for inleo.io",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "*://inleo.io/*",
        "*://*.inleo.io/*",
        "*://api.coingecko.com/*",
        "*://api.deathwing.me/*",
        "*://api.hive.blog/*",
        "*://api.hive-engine.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Inleo Skins"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://inleo.io/*",
                "*://*.inleo.io/*"
            ],
            "js": [
                "features/slateBridge.js"
            ],
            "world": "MAIN",
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://inleo.io/*",
                "*://*.inleo.io/*"
            ],
            "js": [
                "core/logger.js",
                "core/storage.js",
                "core/state.js",
                "core/utils.js",
                "core/scheduler.js",
                "core/routeController.js",
                "data/hashtagEntities.js",
                "data/hashtagRules.js",
                "features/editorTweaks.js",
                "features/marketTicker.js",
                "features/theme.js",
                "features/currentUser.js",
                "features/settingsLink.js",
                "features/sidebarCleanup.js",
                "features/avatarMarkers.js",
                "features/muteFeed.js",
                "features/composerHashtags.js",
                "wallet.js",
                "wallet/walletStyles.js",
                "wallet/walletApi.js",
                "wallet/walletCache.js",
                "wallet/walletView.js",
                "wallet/walletRender.js",
                "wallet/walletModal.js",
                "wallet/walletRoute.js",
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "img/*",
                "themes/*",
                "styles/*"
            ],
            "matches": [
                "*://inleo.io/*",
                "*://*.inleo.io/*"
            ]
        }
    ],
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    }
}